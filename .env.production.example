# =============================================================================
# TEMPLATE ENV PRODUKSI (Railway) — isikan sebagai Variables di dashboard Railway.
# JANGAN commit file .env produksi yang berisi nilai asli.
# =============================================================================

APP_NAME=DiaPredict
APP_ENV=production
APP_KEY=            # WAJIB: `php artisan key:generate --show` lalu tempel di sini
APP_DEBUG=false     # WAJIB false di produksi
APP_URL=https://your-app.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# --- Logging: pakai stderr agar tampil di log Railway ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Database (pakai MySQL plugin Railway; referensikan variabel-nya) ---
# Railway MySQL menyediakan MYSQL* / MYSQLHOST dll. Map ke variabel Laravel:
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# --- Session / Cache / Queue ---
# Untuk skala kecil, "database" cukup. Untuk skala lebih tinggi, ganti ke redis.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# --- Mail (opsional; default log) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@diapredict.app"
MAIL_FROM_NAME="${APP_NAME}"

# --- Python untuk model ML (sudah diset di Dockerfile, override bila perlu) ---
PYTHON_PATH=/opt/venv/bin/python

# --- Kontrol entrypoint ---
RUN_MIGRATIONS=true
